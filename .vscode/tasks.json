{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start App",
      "type": "npm",
      "script": "start",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      },
      "problemMatcher": [],
      "isBackground": true,
      "detail": "Start the Electron application"
    },
    {
      "label": "Stop App",
      "type": "shell",
      "command": "pkill",
      "args": ["-f", "electron"],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": [],
      "detail": "Stop the Electron application"
    }
  ]
}
